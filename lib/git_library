#!/usr/bin/env bash

# ─────────────────────────────────────────
# UTILITIES
# ─────────────────────────────────────────

promptYN() {

    local msg="${1:-"Want to continue?"}"
    local ans

    while true; do
        read -rp "$msg [Y/n]: " ans

        case $ans in
            [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo "Can't you read the prompt?" ;;
        esac
    done
}

repoExists() {
    [ -d ".git" ]
}


# ─────────────────────────────────────────
# REPO MANAGEMENT
# ─────────────────────────────────────────

createRepo() {

    if repoExists; then
        echo "Repo already exists" >&2
        return 1
    fi

    git init -q || return 1
}

branchName() {

    local branch
    local newBranch

    branch=$(git branch --show-current)
    branch="${branch:-"(no branch yet)"}"
    echo "Current branch is $branch"

    if promptYN "Do you want to change the branch name?"; then
        read -rp "Enter new branch name: " newBranch
        newBranch="${newBranch:-main}"
        git branch -m "$newBranch" || return 1
        echo "Branch name changed to $newBranch"
    fi
}

# ─────────────────────────────────────────
# FILE MANAGEMENT  
# ─────────────────────────────────────────

createGitignore() {
    if [ -f ".gitignore" ]; then
        echo ".gitignore already exists" >&2
        return 1
    fi

    touch .gitignore || return 1
    echo ".gitignore created"
}

createReadme() {
    if [ -f "README.md" ]; then
        echo "README.md already exists" >&2
        return 1
    fi

    touch README.md || return 1
    echo "README.md created"
}



# ─────────────────────────────────────────
# STAGING & COMMITS
# ─────────────────────────────────────────

hasCommits() {
    git rev-parse --verify HEAD >/dev/null 2>&1
}

stageFiles() {

    local toAdd="$1"
    local fileName="$2"
    local stagedFiles

    if [[ -z "$toAdd" ]]; then
        echo "usage:"
        echo "  stageFiles <file>     - stage specific file"
        echo "  stageFiles -a         - stage all changes"
        echo "  stageFiles -aq        - stage all quietly"
        echo "  stageFiles -q <file>  - stage specific file quietly"
        return 1
    fi

    case "$toAdd" in
        -a)
            git add .
            stagedFiles=$(git diff --name-only --cached)
            echo "Files staged:"
            echo "$stagedFiles"
            return 0
            ;;

        -aq)
            git add .
            return 0
            ;;

        -q)
            if [[ -z "$fileName" ]]; then
                echo "No file specified for quiet mode" >&2
                return 1
            fi
            if [[ -f "$fileName" ]]; then
                git add "$fileName"
                return 0
            else
                echo "Not a valid file: $fileName" >&2
                return 1
            fi
            ;;
        -ex)
            local groupFile=".bashgit/groups/$fileName"

            if [[ -z "$fileName" ]]; then
                echo "Usage: stageFiles -ex <group_name>" >&2
                return 1
            fi

            if [[ ! -f "$groupFile" ]]; then
                echo "Group '$fileName' not found." >&2
                return 1
            fi

            git status --porcelain \
                | awk '{print $2}' \
                | grep -v -F -f "$groupFile" \
                | xargs -r git add

            echo "Staged all files except group '$fileName'"
            return 0
            ;;

        *)
            if [[ -f "$toAdd" ]]; then
                git add "$toAdd"
                stagedFiles=$(git diff --name-only --cached)
                echo "$stagedFiles"
                return 0
            else
                echo "Not a valid file: $toAdd" >&2
                return 1
            fi
            ;;
    esac
}

commitChanges() {

    local message="$1"

    if [[ -z "$message" ]]; then
        read -rp "Commit message: " message
    fi

    git commit -m "$message" || return 1
}

checkSync() {

    git fetch -q >/dev/null || {
        echo "Failed to fetch from remote" >&2
        return 1
    }

    local localCommit originCommit baseCommit

    localCommit=$(git rev-parse @)

    originCommit=$(git rev-parse @{u} 2>/dev/null) || {
        echo "No upstream set"
        return 0
    }

    baseCommit=$(git merge-base @ @{u})

    if [[ "$localCommit" = "$originCommit" ]]; then
        echo "Up to date"
        return 0

    elif [[ "$localCommit" = "$baseCommit" ]]; then
        echo "Need to pull"
        git log --oneline HEAD..@{u}
        return 1

    elif [[ "$originCommit" = "$baseCommit" ]]; then
        echo "Need to push"
        return 0

    else
        echo "Branches are diverged"
        echo "Remote changes:"
        git log --oneline HEAD..@{u}
        echo
        echo "Local changes:"
        git log --oneline @{u}..HEAD
        return 1
    fi
}

pushChanges() {

    local remote
    local branch

    git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1
    local upStream=$?

    if [[ "$upStream" -eq 0 ]]; then
        git push || {
            echo "Push failed" >&2
            return 1
        }
    else
        if promptYN "Want to set upstream?"; then
            read -rp "Remote: " remote
            read -rp "Branch: " branch
            remote="${remote:-origin}"
            branch="${branch:-$(git branch --show-current)}"

            git push -u "$remote" "$branch" || {
                echo "Push failed" >&2
                return 1
            }
        else
            echo "Aborting push. No upstream set." >&2
            return 1
        fi
    fi
}

gitPush() {

    local stageArgs="${1:-"-a"}"
    local commitMsg="${@:2}"

    if ! hasCommits; then
        echo "No commits yet. Please make an initial commit first." >&2
        return 1
    fi
    checkSync || return 1
    stageFiles "$stageArgs" && commitChanges "$commitMsg" && pushChanges && echo "Changes pushed successfully"

}

# ─────────────────────────────────────────
# GROUP MANAGEMENT
# ─────────────────────────────────────────

grpCreate(){

    local groupName="$1"
    local groupDir=".bashgit/groups"

    if ! repoExists; then
        echo "Not in a git repo root. Run this from your project root." >&2
        exit 1
    fi

    if [[ -z "$groupName" ]]; then
        read -rp "Enter group name: " groupName
    fi

    mkdir -p "$groupDir" || return 1

    if [[ -f "$groupDir/$groupName" ]]; then
        echo "Group '$groupName' already exists" >&2
        return 1
    fi

    touch "$groupDir/$groupName" || return 1
    echo "Group '$groupName' created"

}

grpAdd() {

  local groupName="$1"
  local fileName="$2"
  local groupDir=".bashgit/groups"
  local groupFile="$groupDir/$groupName"

  if [[ ! -f "$groupFile" ]];then 
    echo "Group '$groupName' does not exist." >&2
    return 1
  fi

  if ! grep -qxF "$fileName" "$groupFile"; then
    echo "$fileName" >> "$groupFile"
    echo "Added '$fileName' to group '$groupName'"
  else
    echo "'$fileName' is already in group '$groupName'" >&2
    return 1
  fi

}

grpList(){

    local groupDir=".bashgit/groups"
    ls "$groupDir" 2>/dev/null || echo "No groups found"

}

grpShow(){

    local groupDir=".bashgit/groups"
    local name="$1"

    if [[ -z "$name" ]]; then
        read -rp "Enter group name: " name
    fi

    local groupFile="$groupDir/$name"

    if [[ -f "$groupFile" ]]; then
        cat "$groupFile"
    else
        echo "Group '$name' not found." >&2
        return 1
    fi

}