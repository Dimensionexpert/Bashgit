#!/usr/bin/env bash

# ─────────────────────────────────────────
# UTILITIES
# ─────────────────────────────────────────

promptYN() {

    local msg="${1:-"Want to continue?"}"
    local ans

    while true; do
        read -rp "$msg [Y/n]: " ans

        case $ans in
            [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo "Can't you read the prompt?" ;;
        esac
    done
}

repoExists() {
    [ -d ".git" ]
}


# ─────────────────────────────────────────
# REPO MANAGEMENT
# ─────────────────────────────────────────

createRepo() {

    if repoExists; then
        echo "Repo already exists" >&2
        return 1
    fi

    git init -q || return 1
}

branchName() {

    local branch
    local newBranch

    branch=$(git branch --show-current)
    branch="${branch:-"(no branch yet)"}"
    echo "Current branch is $branch"

    if promptYN "Do you want to change the branch name?"; then
        read -rp "Enter new branch name: " newBranch
        newBranch="${newBranch:-main}"
        git branch -m "$newBranch" || return 1
        echo "Branch name changed to $newBranch"
    fi
}

# ─────────────────────────────────────────
# FILE MANAGEMENT  
# ─────────────────────────────────────────

createGitignore() {
    if [ -f ".gitignore" ]; then
        echo ".gitignore already exists" >&2
        return 1
    fi

    touch .gitignore || return 1
    echo ".gitignore created"
}

createReadme() {
    if [ -f "README.md" ]; then
        echo "README.md already exists" >&2
        return 1
    fi

    touch README.md || return 1
    echo "README.md created"
}



# ─────────────────────────────────────────
# STAGING & COMMITS
# ─────────────────────────────────────────

hasCommits() {
    git rev-parse --verify HEAD >/dev/null 2>&1
}

gitAdd(){
    local input="$1"
    local userGroupName="$2"
    local groupName=".bashgit/groups/$userGroupName"

    case "$input" in
        -a)
            git add . || return 1
            ;;

        -e)
            if [[ -z "$userGroupName" ]]; then
                echo "Usage: -e <user_group_name>"
                promptYN "Do you want to see available groups?" && grpList
                return 1
            fi

            if [[ ! -f "$groupName" ]]; then
                echo "Group '$userGroupName' does not exist." >&2
                promptYN "Do you want to see available groups?" && grpList
                return 1
            fi

            git status --porcelain \
                | awk '{print substr($0, 4)}' \
                | grep -v -F -f "$groupName" \
                | xargs -r -d '\n' git add || return 1
            ;;

        *)
            if [[ -e "$input" ]]; then
                git add "$input" || return 1
            else
                echo "Not a valid file: $input" >&2
                return 1
            fi
            ;;
    esac

    local stagedFiles
    stagedFiles="$(git diff --name-only --cached)"

    if [[ -n "$stagedFiles" ]]; then
        echo "Staged files:"
        echo "$stagedFiles"
    else
        echo "No files staged."
    fi

    return 0

   
}

gitCommit(){
    local message="$1"

    if [[ -z "$message" ]]; then
        echo "Usage: $0 <commit_message>" >&2
        read -rp "Enter the commit message: " message
        if [[ -z "$message" ]]; then
            echo "Commit message cannot be empty. RETARD!!" >&2
            return 1
        fi
    fi

    if ! git diff --cached --quiet; then
        git commit -m "$message" || return 1
        return 0
    else
        echo "No changes to commit."
        return 0
    fi
}

checkSync() {

    git fetch -q >/dev/null || {
        echo "Failed to fetch from remote" >&2
        return 1
    }

    local localCommit originCommit baseCommit

    localCommit=$(git rev-parse @)

    originCommit=$(git rev-parse @{u} 2>/dev/null) || {
        echo "No upstream set"
        return 0
    }

    baseCommit=$(git merge-base @ @{u})

    if [[ "$localCommit" = "$originCommit" ]]; then
        echo "Up to date"
        return 0

    elif [[ "$localCommit" = "$baseCommit" ]]; then
        echo "Need to pull"
        git log --oneline HEAD..@{u}
        return 1

    elif [[ "$originCommit" = "$baseCommit" ]]; then
        echo "Need to push"
        return 0

    else
        echo "Branches are diverged"
        echo "Remote changes:"
        git log --oneline HEAD..@{u}
        echo
        echo "Local changes:"
        git log --oneline @{u}..HEAD
        return 1
    fi
}

gitPush(){

    local hasUpstream
    hasUpstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)"

    if ! hasCommits; then 
        echo "No commits yet. Please make commit first."
        if promptYN "Do you want to initialize now?"; then
            gi || return 1
        else
            echo "Aborting push. No commits to push." >&2
            return 1
        fi
    fi  

    if [[ -z "$hasUpstream" ]]; then
        echo "No upstream branch set."
        if promptYN "Do you want to set upstream?"; then
            read -rp "Remote: " remote
            read -rp "Branch: " branch

            remote="${remote:-origin}"
            branch="${branch:-$(git branch --show-current)}"

            git push -u "$remote" "$branch" || {
                echo "Push failed" >&2
                return 1
            }

            echo "Upstream set and pushed."
            return 0
        else
            echo "Aborting push. No upstream set." >&2
            return 1
        fi
    fi

    git push || {
        echo "Push failed" >&2
        return 1
    }

    echo "Push successful!"
    return 0   
}

gitStageCommitPush() {

    local flag groupName commitMessage

    if [[ "$1" == -* ]]; then
        flag="$1"
        groupName="$2"
        commitMessage="${@:3}"
    else
        flag="-a"
        groupName=""
        commitMessage="${@:1}"
    fi

    checkSync || return 1

    case "$flag" in
        -a)
            gitAdd "$flag" && gitCommit "$commitMessage" && gitPush && echo "Pushed successfully :)"
            ;;
        -e)
            gitAdd "$flag" "$groupName" && gitCommit "$commitMessage" && gitPush && echo "Pushed successfully :)"
            ;;
        -q)
            gitAdd -a >/dev/null && gitCommit "$commitMessage" >/dev/null && gitPush >/dev/null && echo "Pushed successfully :)"
            ;;
        -eq)
            gitAdd -e "$groupName" >/dev/null && gitCommit "$commitMessage" >/dev/null && gitPush >/dev/null && echo "Pushed successfully :)"
            ;;
        *)
            echo "Invalid flag." >&2
            return 1
            ;;
    esac
}

# ─────────────────────────────────────────
# GROUP MANAGEMENT
# ─────────────────────────────────────────

grpCreate(){

    local groupName="$1"
    local groupDir=".bashgit/groups"

    if ! repoExists; then
        echo "Not in a git repo root. Run this from your project root." >&2
        exit 1
    fi

    if [[ -z "$groupName" ]]; then
        read -rp "Enter group name: " groupName
    fi

    mkdir -p "$groupDir" || return 1

    if [[ -f "$groupDir/$groupName" ]]; then
        echo "Group '$groupName' already exists" >&2
        return 1
    fi

    touch "$groupDir/$groupName" || return 1
    echo "Group '$groupName' created"

}

grpAdd() {

  local groupName="$1"
  local fileName="$2"
  local groupDir=".bashgit/groups"
  local groupFile="$groupDir/$groupName"

  if [[ ! -f "$groupFile" ]];then 
    echo "Group '$groupName' does not exist." >&2
    return 1
  fi

  if ! grep -qxF "$fileName" "$groupFile"; then
    echo "$fileName" >> "$groupFile"
    echo "Added '$fileName' to group '$groupName'"
  else
    echo "'$fileName' is already in group '$groupName'" >&2
    return 1
  fi

}

grpList(){

    local groupDir=".bashgit/groups"
    ls "$groupDir" 2>/dev/null || echo "No groups found"

}

grpShow(){

    local groupDir=".bashgit/groups"
    local name="$1"

    if [[ -z "$name" ]]; then
        read -rp "Enter group name: " name
    fi

    local groupFile="$groupDir/$name"

    if [[ -f "$groupFile" ]]; then
        cat "$groupFile"
    else
        echo "Group '$name' not found." >&2
        return 1
    fi

}